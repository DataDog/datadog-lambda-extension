FROM scratch
ARG TARGETARCH
ARG SUFFIX

COPY --mount=type=bind,source=.layers/datadog_extension-${TARGETARCH}${SUFFIX}/extensions/datadog-agent,target=/tmp/extensions/datadog-agent /opt/extensions/datadog-agent
COPY --mount=type=bind,source=.layers/datadog_extension-${TARGETARCH}${SUFFIX}/datadog-agent-go,target=/tmp/datadog-agent-go /opt/datadog-agent-go
COPY --mount=type=bind,source=scripts/datadog_wrapper,target=/tmp/datadog_wrapper --chmod=0755 /opt/datadog_wrapper
